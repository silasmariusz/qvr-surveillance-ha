# QVR Surveillance - standalone integration (no pyqvrpro)
# Copy to configuration.yaml

qvr_surveillance:
  host: 10.100.200.10
  username: admin
  password: "your_password"
  use_ssl: false
  port: 38080  # QVR Surveillance default; QVR Pro uses 8080
  exclude_channels: []
  client_id: qvr_surveillance
  # stream_index: 0  # 0=Main (best), 1=Substream, 2=Mobile
